{
  "id": "clawmeeting",
  "name": "ClawMeeting - AI Meeting Negotiator",
  "version": "1.0.74",
  "description": "Intelligent meeting negotiation plugin. Provides 5 tools: bind_identity, verify_email_code, initiate_meeting, check_and_respond_tasks, list_meetings. All meeting operations must go through these tools — never call external APIs directly.",
  "skills": ["./skills"],
  "compat": {
    "pluginApi": ">=2026.4.0",
    "builtWith": "2026.4.1"
  },
  "configSchema": {
    "type": "object",
    "properties": {
      "serverUrl": {
        "type": "string",
        "description": "Coordination server API URL",
        "default": "https://memcontext.ai/clawmeeting_api"
      },
      "pollingIntervalMs": {
        "type": "number",
        "description": "Polling interval for pending tasks (milliseconds)",
        "default": 10000
      },
      "autoRespond": {
        "type": "boolean",
        "description": "Automatically respond to INITIAL_SUBMIT tasks",
        "default": true
      }
    }
  },
  "uiHints": {
    "serverUrl": { "label": "Server URL", "placeholder": "https://memcontext.ai/clawmeeting_api" },
    "pollingIntervalMs": { "label": "Polling interval (ms)", "placeholder": "10000" },
    "autoRespond": { "label": "Auto-respond to meeting invitations" }
  }
}
