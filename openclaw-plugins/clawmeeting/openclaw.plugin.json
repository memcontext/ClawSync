{
  "id": "clawmeeting",
  "name": "ClawMeeting - AI Meeting Negotiator",
  "version": "1.0.0",
  "description": "智能会议协商代理插件 - 作为用户的贴身助理，负责收集情报、保护隐私并代表用户进行初步博弈",
  "skills": ["./skills"],
  "configSchema": {
    "type": "object",
    "properties": {
      "serverUrl": {
        "type": "string",
        "description": "中央协调端 API Server 地址",
        "default": "http://192.168.22.28:8000"
      },
      "pollingIntervalMs": {
        "type": "number",
        "description": "轮询待办任务的间隔（毫秒）",
        "default": 10000
      },
      "autoRespond": {
        "type": "boolean",
        "description": "是否自动响应 INITIAL_SUBMIT 类型任务",
        "default": true
      }
    }
  },
  "uiHints": {
    "serverUrl": { "label": "服务端地址", "placeholder": "http://39.105.143.2:7010" },
    "pollingIntervalMs": { "label": "轮询间隔 (ms)", "placeholder": "10000" },
    "autoRespond": { "label": "自动响应会议邀请" }
  }
}
